{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"root": false,
	"extends": "//",
	"files": {
		"includes": ["**", "!build", "!.adonisjs", "!database/schema.ts"]
	},
	"linter": {
		"domains": {
			"test": "recommended"
		},
		"rules": {
			"style": {
				"useImportType": "off",
				"noNonNullAssertion": "off",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["./**", "../**"],
								"message": "Use alias imports instead of relative imports."
							}
						]
					}
				}
			}
		}
	}
}
