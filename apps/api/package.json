{
	"name": "@workspace/api",
	"author": "elowanaud",
	"type": "module",
	"exports": {
		"./registry": "./.adonisjs/client/registry/index.ts",
		"./data": "./.adonisjs/client/data.d.ts"
	},
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "node ace serve --hmr",
		"worker": "node ace queue:work --queue=emails",
		"test": "node ace test",
		"typecheck": "tsc --noEmit",
		"docker-compose": "docker compose up --remove-orphans"
	},
	"imports": {
		"#config/*": "./config/*.js",
		"#controllers/*": "./src/controllers/*.js",
		"#database/*": "./database/*.js",
		"#exceptions/*": "./src/exceptions/*.js",
		"#features/*": "./src/features/*.js",
		"#generated/*": "./.adonisjs/server/*.js",
		"#validators/*": "./src/validators/*.js",
		"#middlewares/*": "./src/middlewares/*.js",
		"#policies/*": "./src/policies/*.js",
		"#models/*": "./src/models/*.js",
		"#presenters/*": "./src/presenters/*.js",
		"#hooks/*": "./hooks/*.js",
		"#services/*": "./src/services/*.js",
		"#src/*": "./src/*.js",
		"#start/*": "./start/*.js",
		"#tests/*": "./tests/*.js"
	},
	"dependencies": {
		"@adonisjs/auth": "10.1.0",
		"@adonisjs/bouncer": "4.0.0",
		"@adonisjs/core": "7.3.4",
		"@adonisjs/cors": "3.0.0",
		"@adonisjs/drive": "^4.0.0",
		"@adonisjs/limiter": "3.0.1",
		"@adonisjs/lucid": "22.4.2",
		"@adonisjs/mail": "10.4.0",
		"@adonisjs/queue": "0.6.2",
		"@adonisjs/redis": "10.0.0",
		"@adonisjs/session": "8.1.0",
		"@aws-sdk/client-s3": "^3.1075.0",
		"@aws-sdk/s3-request-presigner": "^3.1079.0",
		"@tuyau/core": "1.2.2",
		"@tuyau/superjson": "1.0.0",
		"@vinejs/vine": "4.4.0",
		"@workspace/ui-theme": "workspace:*",
		"edge.js": "6.5.1",
		"luxon": "3.7.2",
		"mjml": "5.4",
		"pg": "8.22.0",
		"reflect-metadata": "0.2.2"
	},
	"devDependencies": {
		"@adonisjs/assembler": "8.4.0",
		"@adonisjs/tsconfig": "2.0.0",
		"@japa/api-client": "^3.2.1",
		"@japa/assert": "4.2.0",
		"@japa/plugin-adonisjs": "5.2.0",
		"@japa/runner": "5.3.0",
		"@poppinss/ts-exec": "1.4.4",
		"@types/luxon": "3.7.2",
		"@types/node": "24",
		"hot-hook": "1.0.0",
		"pino-pretty": "13.1.3",
		"typescript": "6.0.3"
	}
}
