{
	"name": "@workspace/api",
	"author": "elowanaud",
	"type": "module",
	"exports": {
		"./registry": "./.adonisjs/client/registry/index.ts",
		"./data": "./.adonisjs/client/data.d.ts"
	},
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "node ace serve --hmr",
		"test": "node ace test",
		"typecheck": "tsc --noEmit",
		"docker-compose": "docker compose up"
	},
	"imports": {
		"#config/*": "./config/*.js",
		"#controllers/*": "./src/controllers/*.js",
		"#database/*": "./database/*.js",
		"#exceptions/*": "./src/exceptions/*.js",
		"#features/*": "./src/features/*.js",
		"#generated/*": "./.adonisjs/server/*.js",
		"#middlewares/*": "./src/middlewares/*.js",
		"#models/*": "./src/models/*.js",
		"#services/*": "./src/services/*.js",
		"#src/*": "./src/*.js",
		"#start/*": "./start/*.js",
		"#tests/*": "./tests/*.js"
	},
	"dependencies": {
		"@adonisjs/auth": "10.1.0",
		"@adonisjs/core": "7.3.2",
		"@adonisjs/cors": "3.0.0",
		"@adonisjs/lucid": "22.4.2",
		"@adonisjs/session": "8.1.0",
		"@tuyau/core": "1.2.2",
		"@tuyau/superjson": "1.0.0",
		"@vinejs/vine": "4.4.0",
		"luxon": "3.7.2",
		"pg": "8.20.0",
		"reflect-metadata": "0.2.2"
	},
	"devDependencies": {
		"@adonisjs/assembler": "8.4.0",
		"@adonisjs/tsconfig": "2.0.0",
		"@japa/assert": "4.2.0",
		"@japa/plugin-adonisjs": "5.2.0",
		"@japa/runner": "5.3.0",
		"@poppinss/ts-exec": "1.4.4",
		"@types/luxon": "3.7.1",
		"@types/node": "25.6.0",
		"hot-hook": "1.0.0",
		"pino-pretty": "13.1.3",
		"typescript": "6.0.3"
	}
}
