{
	"name": "@workspace/ui-theme",
	"author": "elowanaud",
	"type": "module",
	"exports": {
		"./tokens": "./src/tokens.ts",
		"./tailwind": "./src/tailwind.css"
	},
	"scripts": {
		"build": "pnpm generate:tailwind",
		"dev": "nodemon scripts/generate-tailwind.js --watch src/tokens.ts -e ts -q",
		"typecheck": "tsc --noEmit",
		"generate:tailwind": "node scripts/generate-tailwind.js"
	},
	"devDependencies": {
		"nodemon": "3.1.14",
		"typescript": "6.0.3"
	}
}
