{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"root": false,
	"extends": "//",
	"linter": {
		"domains": {
			"react": "recommended",
			"tailwind": "recommended"
		},
		"rules": {
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"fix": "safe",
					"options": {
						"functions": ["tv", "cn"]
					}
				}
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
